name: ompzed
title: Ompzed
base: core24
version: "$RELEASE_VERSION"
summary: An OMP-native code editor
description: |
  Ompzed is an OMP-native fork of the Zed code editor, built in Rust with a
  GPU-accelerated renderer and the Oh My Pi agent as a first-class citizen.
grade: stable
confinement: classic
compression: lzo
website: https://github.com/DylanMcCavitt/ompzed
source-code: https://github.com/DylanMcCavitt/ompzed
issues: https://github.com/DylanMcCavitt/ompzed/issues
contact: https://github.com/DylanMcCavitt/ompzed/issues

parts:
  ompzed:
    plugin: dump
    # The Ompzed fork must publish this release artifact; this no longer pulls
    # an upstream Zed binary. See docs/src/omp/distribution-identity.md.
    source: "https://github.com/DylanMcCavitt/ompzed/releases/download/v$RELEASE_VERSION/zed-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Ompzed exits
      # with "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Ompzed exits
      # with "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  ompzed:
    # The bundled binary is still named `zed` (build output); see
    # docs/src/omp/distribution-identity.md.
    command: usr/bin/zed
    common-id: dev.ompzed.Ompzed
    environment:
      ZED_BUNDLE_TYPE: snap
